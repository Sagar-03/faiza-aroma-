{% comment %}
  Best Sellers Slider Section
  Matches the Adilqadri-style dark maroon layout with gold accents.
  Products are managed via the section settings in Shopify admin.
{% endcomment %}

{% assign bg_image = section.settings.bg_image %}
<section
  class="best-sellers-section full-width{% if bg_image != blank %} has-bg-image{% endif %}"
  id="best-sellers-{{ section.id }}"
  {% if bg_image != blank %}
    style="background-image: url('{{ bg_image | img_url: '2000x' }}'); background-color: {{ section.settings.bg_color | default: '#5a1a1a' }};"
  {% else %}
    style="background-color: {{ section.settings.bg_color | default: '#5a1a1a' }};"
  {% endif %}
>
  <div class="best-sellers-inner">

    <div class="best-sellers-header">
      <h2 class="best-sellers-title">Explore Our Best Sellers</h2>
      <div class="best-sellers-nav">
        <button class="slider-btn slider-btn--prev" aria-label="Previous" data-section="{{ section.id }}">
          &#8592;
        </button>
        <button class="slider-btn slider-btn--next" aria-label="Next" data-section="{{ section.id }}">
          &#8594;
        </button>
      </div>
    </div>

    <div class="slider-viewport" data-slider-viewport="{{ section.id }}">
      <div class="slider-track" data-slider-track="{{ section.id }}">

        {% for block in section.blocks %}
          {% assign product = block.settings.product %}
          {% if product != blank %}
            <div class="product-card" {{ block.shopify_attributes }}>

              {% if block.settings.badge != blank %}
                <div class="product-badge">
                  <span class="badge-icon">&#9889;</span>
                  {{ block.settings.badge }}
                </div>
              {% endif %}

              <a href="{{ product.url }}" class="product-image-link">
                <div class="product-image-wrap">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="product-img"
                      loading="lazy"
                      width="500"
                      height="500"
                    >
                  {% else %}
                    <div class="product-img-placeholder">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                  {% endif %}
                </div>
              </a>

              <div class="product-info">

                {% if product.metafields.custom.product_type != blank %}
                  <p class="product-type">{{ product.metafields.custom.product_type }}</p>
                {% elsif product.type != blank %}
                  <p class="product-type">{{ product.type | upcase }}</p>
                {% endif %}

                <div class="product-rating-row">
                  {% assign rating = product.metafields.reviews.rating.value %}
                  {% assign count = product.metafields.reviews.rating_count.value %}
                  {% if rating != blank %}
                    <span class="rating-star">&#9733;</span>
                    <span class="rating-value">{{ rating }}</span>
                    {% if count != blank %}
                      <span class="rating-count">| {{ count }}</span>
                    {% endif %}
                  {% endif %}
                </div>

                <a href="{{ product.url }}" class="product-title">{{ product.title }}</a>

                <div class="product-price-row">
                  <span class="price-current">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                    {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                    <span class="price-badge">{{ discount }}% off</span>
                  {% endif %}
                </div>

                {% if block.settings.emi_text != blank %}
                  <p class="product-emi">
                    or {{ block.settings.emi_text }}
                    <a href="{{ block.settings.emi_link | default: '#' }}" class="emi-link">Buy on EMI &rsaquo;</a>
                  </p>
                {% endif %}

              </div>

              <div class="product-card-footer">
                <button
                  class="add-to-cart-btn"
                  data-product-id="{{ product.variants.first.id }}"
                  onclick="addToCart('{{ product.variants.first.id }}', this)"
                >
                  ADD TO CART
                  <span class="cart-icon">&#128722;</span>
                </button>
              </div>

            </div>
          {% endif %}
        {% endfor %}

      </div>
    </div>

  </div>
</section>

<style>
  .best-sellers-wrapper {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
  }

  .shopify-section:has(.best-sellers-section) {
    padding: 0 !important;
    margin: 0 !important;
    gap: 0 !important;
  }

  .best-sellers-section {
    background-color: {{ section.settings.bg_color | default: '#5a1a1a' }};
    padding: 48px 0 56px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow: hidden;
  }

  .best-sellers-section.has-bg-image {
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  .best-sellers-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .best-sellers-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .best-sellers-title {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .best-sellers-nav {
    display: flex;
    gap: 12px;
  }

  .slider-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid #c9a84c;
    background: transparent;
    color: #c9a84c;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
    line-height: 1;
  }

  .slider-btn:hover {
    background: #c9a84c;
    color: #ffffff;
  }

  .slider-btn:focus-visible {
    outline: 2px solid #c9a84c;
    outline-offset: 3px;
  }

  .slider-viewport {
    overflow: hidden;
    width: 100%;
  }

  .slider-track {
    display: flex;
    gap: 20px;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .product-card {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    min-width: calc(25% - 15px);
    max-width: calc(25% - 15px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    background: #1a1a1a;
    color: #ffffff;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 0.03em;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .badge-icon {
    color: #f0c040;
    font-size: 10px;
  }

  .product-image-link {
    display: block;
    text-decoration: none;
  }

  .product-image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f5f5f5;
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .product-card:hover .product-img {
    transform: scale(1.04);
  }

  .product-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e8e8;
  }

  .product-img-placeholder .placeholder-svg {
    width: 60%;
    height: 60%;
    fill: #cccccc;
  }

  .product-info {
    padding: 14px 16px 8px;
    flex: 1;
  }

  .product-type {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #888888;
    margin: 0 0 4px;
    text-transform: uppercase;
  }

  .product-rating-row {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 6px;
    min-height: 18px;
  }

  .rating-star {
    color: #f5a623;
    font-size: 13px;
  }

  .rating-value {
    font-size: 12px;
    font-weight: 600;
    color: #333333;
  }

  .rating-count {
    font-size: 12px;
    color: #888888;
  }

  .product-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    line-height: 1.35;
    margin-bottom: 10px;
  }

  .product-title:hover {
    color: #5a1a1a;
  }

  .product-price-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }

  .price-current {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .price-compare {
    font-size: 13px;
    color: #999999;
    text-decoration: line-through;
  }

  .price-badge {
    background: #2d7a2d;
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 4px;
  }

  .product-emi {
    font-size: 11px;
    color: #666666;
    margin: 0 0 4px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .emi-link {
    color: #1a1a1a;
    font-size: 10px;
    font-weight: 600;
    border: 1px solid #cccccc;
    padding: 1px 6px;
    border-radius: 3px;
    text-decoration: none;
  }

  .emi-link:hover {
    background: #f5f5f5;
  }

  .product-card-footer {
    padding: 12px 16px 16px;
  }

  .add-to-cart-btn {
    width: 100%;
    background: linear-gradient(135deg, #c9a84c 0%, #a8872e 100%);
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 13px 16px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: opacity 0.2s, transform 0.15s;
  }

  .add-to-cart-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .add-to-cart-btn:active {
    transform: translateY(0);
  }

  .add-to-cart-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .cart-icon {
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .product-card {
      min-width: calc(33.333% - 14px);
      max-width: calc(33.333% - 14px);
    }
  }

  @media (max-width: 768px) {
    .product-card {
      min-width: calc(50% - 10px);
      max-width: calc(50% - 10px);
    }
    .best-sellers-title {
      font-size: 20px;
    }
  }

  @media (max-width: 480px) {
    .product-card {
      min-width: calc(80% - 10px);
      max-width: calc(80% - 10px);
    }
    .best-sellers-inner {
      padding: 0 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .slider-track {
      transition: none;
    }
    .product-img {
      transition: none;
    }
  }
</style>

<script>
  (function () {
    var sectionId = '{{ section.id }}';

    function initSlider(id) {
      var track = document.querySelector('[data-slider-track="' + id + '"]');
      var viewport = document.querySelector('[data-slider-viewport="' + id + '"]');
      var prevBtn = document.querySelector('.slider-btn--prev[data-section="' + id + '"]');
      var nextBtn = document.querySelector('.slider-btn--next[data-section="' + id + '"]');

      if (!track || !viewport || !prevBtn || !nextBtn) return;

      var cards = track.querySelectorAll('.product-card');
      if (cards.length === 0) return;

      var currentIndex = 0;

      function getVisibleCount() {
        var vw = viewport.offsetWidth;
        if (vw < 480) return 1;
        if (vw < 768) return 2;
        if (vw < 1024) return 3;
        return 4;
      }

      function getCardWidth() {
        var card = cards[0];
        var style = window.getComputedStyle(track);
        var gap = parseFloat(style.columnGap || style.gap || '20');
        return card.offsetWidth + gap;
      }

      function maxIndex() {
        return Math.max(0, cards.length - getVisibleCount());
      }

      function goTo(index) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        var offset = currentIndex * getCardWidth();
        track.style.transform = 'translateX(-' + offset + 'px)';
        prevBtn.disabled = currentIndex === 0;
        nextBtn.disabled = currentIndex >= maxIndex();
      }

      prevBtn.addEventListener('click', function () {
        goTo(currentIndex - 1);
      });

      nextBtn.addEventListener('click', function () {
        goTo(currentIndex + 1);
      });

      window.addEventListener('resize', function () {
        goTo(0);
      });

      goTo(0);
    }

    document.addEventListener('DOMContentLoaded', function () {
      initSlider(sectionId);
    });

    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', function (e) {
        if (e.detail && e.detail.sectionId === sectionId) {
          initSlider(sectionId);
        }
      });
    }
  })();
</script>

<script>
  function addToCart(variantId, btn) {
    btn.disabled = true;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
      .then(function (res) {
        if (!res.ok) throw new Error('Failed to add');
        return res.json();
      })
      .then(function () {
        btn.textContent = 'Added!';
        setTimeout(function () {
          btn.innerHTML = 'ADD TO CART <span class="cart-icon">&#128722;</span>';
          btn.disabled = false;
        }, 1500);

        document.dispatchEvent(new CustomEvent('cart:updated'));
      })
      .catch(function () {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      });
  }
</script>

{% schema %}
{
  "name": "Best Sellers Slider",
  "tag": "section",
  "class": "best-sellers-wrapper",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#5a1a1a",
      "info": "Used as fallback if no background image is set"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Optional. Upload a texture or pattern. Covers the full section."
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "info": "e.g. Best Seller, New Arrival, Summer Special"
        },
        {
          "type": "text",
          "id": "emi_text",
          "label": "EMI Text",
          "placeholder": "e.g. or 133/Month"
        },
        {
          "type": "url",
          "id": "emi_link",
          "label": "EMI Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Sellers Slider",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
