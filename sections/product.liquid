  font-size: var(--faiza-size-lg);
  color: var(--faiza-cream);
}

.fp-product__combo-save {
  font-size: var(--faiza-size-sm);
  color: #16a34a;
  font-weight: 600;
}

.fp-product__combo-cta { width: 100%; }

/* ── Feature banners ───────────────────────────────────── */
.fp-product__feature-banners {
  display: flex;
  flex-direction: column;
  gap: 24px;
  margin: 48px 0;
}

.fp-product__feature-banner {
  width: 100%;
  overflow: hidden;
  border-radius: 12px;
}

.fp-product__feature-banner-img {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 12px;
}

/* ── Related products slider ─────────────────────────────── */
.fp-product__related {
  padding-top: var(--faiza-sp-16);
  padding-bottom: var(--faiza-sp-16);
