}

.fp-product__combo-body {
  display: flex;
  flex-direction: column;
  gap: var(--faiza-sp-3);
}

.fp-product__combo-tag {
  display: inline-block;
  background: #fef9c3;
  color: #854d0e;
  border: 1px solid #fde68a;
