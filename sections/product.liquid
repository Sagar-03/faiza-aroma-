  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--faiza-sp-6);
}

.fp-product__combo-card {
  position: relative;
  border: var(--faiza-border-soft);
  background: var(--faiza-bg-surface);
  padding: var(--faiza-sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--faiza-sp-4);
}

.fp-product__combo-badge {
  position: absolute;
  top: -1px;
  right: -1px;
  background: var(--faiza-gold);
  color: #1a1614;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 4px 10px;
