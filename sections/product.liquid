{% comment %}
  Product page — Adilqadri layout.
{% endcomment %}

<div class="fp-product">
  <div class="faiza-container fp-product__wrap">

    {%- assign current_variant = product.selected_or_first_available_variant -%}

    <!-- ─── Main 2-column layout ─────────────────────────────── -->
    <div class="fp-product__layout">

      <!-- LEFT ── Gallery -->
      <div class="fp-product__gallery">

        <!-- Main stage -->
        <div class="fp-product__stage" id="fp-stage">

          <!-- Discount / Best Seller badge -->
          {%- assign cv = current_variant -%}
          {%- if section.settings.show_trending_badge -%}
            <div class="fp-product__stage-badge" id="fp-stage-badge">{{ section.settings.trending_text }}</div>
          {%- elsif cv.compare_at_price > cv.price -%}
            {%- assign pct_off = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price -%}
            <div class="fp-product__stage-badge" id="fp-stage-badge">{{ pct_off }}% {{ 'general.off' | t }}</div>
          {%- else -%}
            <div class="fp-product__stage-badge fp-product__stage-badge--hidden" id="fp-stage-badge"></div>
          {%- endif -%}

          <!-- Media slides -->
          {% for media in product.media %}
            <div
              class="fp-product__slide{% if forloop.first %} fp-product__slide--active{% endif %}"
              data-fp-idx="{{ forloop.index0 }}"
              data-fp-media-id="{{ media.id }}"
            >
              {%- if media.media_type == 'video' -%}
                {{- media | video_tag: autoplay: false, loop: false, controls: true, class: 'fp-product__stage-img' -}}
              {%- elsif media.media_type == 'external_video' -%}
                {{- media | external_video_tag: class: 'fp-product__stage-img' -}}
              {%- else -%}
                {%- assign stage_alt = media.alt | escape -%}
                {%- if forloop.first -%}
                  {%- assign stage_loading = 'eager' -%}
                {%- else -%}
                  {%- assign stage_loading = 'lazy' -%}
                {%- endif -%}
                {{- media | image_url: width: 900 | image_tag:
                    class: 'fp-product__stage-img',
                    loading: stage_loading,
                    alt: stage_alt,
                    widths: '450, 600, 750, 900'
                -}}
              {%- endif -%}
            </div>
          {% else %}
            <div class="fp-product__slide fp-product__slide--active" data-fp-idx="0">
              {{ 'product-1' | placeholder_svg_tag: 'fp-product__stage-img' }}
            </div>
          {% endfor %}

          <!-- Nav arrows -->
          {% if product.media.size > 1 %}
            <button class="fp-product__arrow fp-product__arrow--prev" id="fp-prev" type="button" aria-label="Previous image">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="fp-product__arrow fp-product__arrow--next" id="fp-next" type="button" aria-label="Next image">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          {% endif %}

        </div><!-- /fp-product__stage -->

        <!-- Thumbnail strip below stage -->
        <div class="fp-product__thumbs" id="fp-thumbs">
          {% for media in product.media %}
            <button
              class="fp-product__thumb{% if forloop.first %} fp-product__thumb--active{% endif %}"
              type="button"
              data-fp-idx="{{ forloop.index0 }}"
              aria-label="View image {{ forloop.index }} of {{ product.media.size }}"
            >
              {%- assign thumb_alt = media.alt | escape -%}
              {{- media.preview_image | image_url: width: 160 | image_tag:
                  loading: 'lazy',
                  class: 'fp-product__thumb-img',
                  alt: thumb_alt,
                  widths: '80, 160'
              -}}
            </button>
          {% else %}
            <button class="fp-product__thumb fp-product__thumb--active" type="button" data-fp-idx="0" aria-label="Product image">
              {{ 'product-1' | placeholder_svg_tag: 'fp-product__thumb-img' }}
            </button>
          {% endfor %}
        </div>

      </div><!-- /fp-product__gallery -->

      <!-- RIGHT ── Product info -->
      <div class="fp-product__info" id="fp-info">

        <!-- Breadcrumb -->
        <nav class="fp-product__bc" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}" class="fp-product__bc-link">Home</a>
          {%- if collection -%}
            <span class="fp-product__bc-sep" aria-hidden="true">/</span>
            <a href="{{ collection.url }}" class="fp-product__bc-link">{{ collection.title }}</a>
          {%- endif -%}
          <span class="fp-product__bc-sep" aria-hidden="true">/</span>
          <span class="fp-product__bc-cur">{{ product.title }}</span>
        </nav>


        <!-- Title -->
        <h1 class="fp-product__title">{{ product.title }}</h1>

        <!-- Product tag chips -->
        {%- if product.tags.size > 0 -%}
          <div class="fp-product__tags">
            {%- for tag in product.tags -%}
              <span class="fp-product__tag">
                <svg class="fp-product__tag-check" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0z"/></svg>
                {{ tag }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Price block -->
        <div class="fp-product__price-block" id="fp-price-block">
          <div class="fp-product__prices">
            <span
              class="fp-product__price{% if current_variant.compare_at_price > current_variant.price %} fp-product__price--sale{% endif %}"
              id="fp-price"
              data-fp-raw="{{ current_variant.price }}"
            >{{ current_variant.price | money }}</span>

            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="fp-product__compare" id="fp-compare" data-fp-raw="{{ current_variant.compare_at_price }}">{{ current_variant.compare_at_price | money }}</span>
              {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
              <span class="fp-product__save" id="fp-save">{{ save_pct }}% {{ 'general.off' | t }}</span>
            {%- else -%}
              <span class="fp-product__compare fp-product__compare--hidden" id="fp-compare"></span>
              <span class="fp-product__save fp-product__save--hidden" id="fp-save"></span>
            {%- endif -%}
          </div>
          <p class="fp-product__tax-note">{{ 'products.product.tax_included' | t }}</p>
        </div>

        <!-- Collection product strip -->
        {% assign fp_cstrip = product.metafields.custom.category_collection.value %}
        {% if fp_cstrip != blank %}
          <div class="fp-cstrip">
            <p class="fp-cstrip__hd">
              <strong>Attars:</strong>
              <span>{{ fp_cstrip.title }}</span>
            </p>
            <div class="fp-cstrip__grid">
              {% for csp in fp_cstrip.products limit: 20 %}
                <a
                  href="{{ csp.url }}"
                  class="fp-cstrip__card{% if csp.handle == product.handle %} fp-cstrip__card--active{% endif %}"
                >
                  <div class="fp-cstrip__img-wrap">
                    {% if csp.featured_image %}
                      {{ csp.featured_image
                        | image_url: width: 300
                        | image_tag:
                          class: 'fp-cstrip__img',
                          loading: 'lazy',
                          alt: csp.title
                      }}
                    {% endif %}
                  </div>
                  <div class="fp-cstrip__body">
                    <p class="fp-cstrip__name">{{ csp.title | truncate: 30 }}</p>
                    <div class="fp-cstrip__prices">
                      <span class="fp-cstrip__price">{{ csp.price | money }}</span>
                      {% if csp.compare_at_price > csp.price %}
                        <span class="fp-cstrip__compare">{{ csp.compare_at_price | money }}</span>
                      {% endif %}
                    </div>
                  </div>
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <!-- Product form -->
        {% form 'product', product, id: 'fp-form', class: 'fp-product__form' %}

          <!-- Variant swatches -->
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="fp-product__opt-group">
                <div class="fp-product__opt-hd">
                  <span class="fp-product__opt-name">{{ option.name }}</span>
                  <span class="fp-product__opt-val" id="fp-opt-val-{{ option.position }}">{{ option.selected_value }}</span>
                </div>
                <div class="fp-product__swatches">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="fp-product__swatch{% if option.selected_value == value %} fp-product__swatch--on{% endif %}"
                      data-fp-pos="{{ option.position }}"
                      data-fp-val="{{ value | escape }}"
                      aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                    >{{ value }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}

            <select name="id" id="fp-variant-select" class="faiza-sr-only" aria-label="{{ 'products.product.choose_options' | t }}">
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {% if variant == current_variant %}selected{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                  data-fp-price="{{ variant.price | money }}"
                  data-fp-compare="{{ variant.compare_at_price | money }}"
                  data-fp-price-raw="{{ variant.price }}"
                  data-fp-compare-raw="{{ variant.compare_at_price }}"
                  data-fp-opt1="{{ variant.option1 | escape }}"
                  data-fp-opt2="{{ variant.option2 | escape }}"
                  data-fp-opt3="{{ variant.option3 | escape }}"
                  data-fp-media-id="{{ variant.featured_media.id }}"
                >{{ variant.title }}</option>
              {%- endfor -%}
            </select>

          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endunless -%}

          <!-- Qty + Add to Cart -->
          <div class="fp-product__cta-row">
            <div class="fp-product__qty">
              <button type="button" class="fp-product__qty-btn" id="fp-qty-minus" aria-label="Decrease quantity">−</button>
              <input
                type="number"
                name="quantity"
                id="fp-qty"
                value="1"
                min="1"
                class="fp-product__qty-input"
                aria-label="{{ 'products.product.quantity' | t }}"
              >
              <button type="button" class="fp-product__qty-btn" id="fp-qty-plus" aria-label="Increase quantity">+</button>
            </div>

            <button
              type="submit"
              name="add"
              id="fp-add-btn"
              class="fp-product__add-btn"
              {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}
              data-fp-add="{{ 'products.product.add_to_cart' | t }}"
              data-fp-sold="{{ 'products.product.sold_out' | t }}"
            >
              <span id="fp-add-label">
                {%- if current_variant.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </span>
              <svg class="fp-product__add-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            </button>
          </div>

          {%- if section.settings.show_buy_now -%}
            <div class="fp-product__cta-secondary">
              <button type="button" id="fp-buy-btn" class="faiza-btn faiza-btn--dark fp-product__buy-btn">
                <span class="faiza-btn__label">{{ section.settings.buy_now_text }}</span>
              </button>
            </div>
          {%- endif -%}

        {% endform %}

        <!-- Delivery info -->
        {%- if section.settings.show_delivery -%}
          <div class="fp-product__delivery">
            <svg class="fp-product__delivery-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13" rx="1"/>
              <path d="M16 8h4l3 5v3h-7V8z"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <span>{{ section.settings.delivery_text }}</span>
          </div>
        {%- endif -%}

      </div><!-- /fp-product__info -->
    </div><!-- /fp-product__layout -->

    <!-- ─── Highlight banner ────────────────────────────────────── -->
    {%- if section.settings.highlight_banner != blank -%}
      <div class="fp-product__highlight">
        {%- assign fp_highlight_alt = product.title | escape -%}
        {{ section.settings.highlight_banner | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'fp-product__highlight-img', alt: fp_highlight_alt }}
      </div>
    {%- endif -%}

    <!-- ─── Trust badges ──────────────────────────────────────── -->
    {%- if section.settings.show_trust_badges -%}
      <div class="fp-product__trust">
        <div class="fp-product__trust-item">
          <div class="fp-product__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4"/></svg>
          </div>
          <span class="fp-product__trust-label">{{ section.settings.trust_label_1 }}</span>
        </div>
        <div class="fp-product__trust-item">
          <div class="fp-product__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </div>
          <span class="fp-product__trust-label">{{ section.settings.trust_label_2 }}</span>
        </div>
        <div class="fp-product__trust-item">
          <div class="fp-product__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <span class="fp-product__trust-label">{{ section.settings.trust_label_3 }}</span>
        </div>
        <div class="fp-product__trust-item">
          <div class="fp-product__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <span class="fp-product__trust-label">{{ section.settings.trust_label_4 }}</span>
        </div>
      </div>
    {%- endif -%}

    <!-- ─── Product accordions ──────────────────────────────── -->
    <div class="fp-product__accordions">

      {%- if section.settings.ingredients_content != blank -%}
        <div class="fp-product__accordion">
          <button class="fp-product__accordion-btn" type="button" aria-expanded="false" aria-controls="fp-acc-ingr">
            <span class="fp-product__accordion-title">{{ section.settings.ingredients_label }}</span>
            <svg class="fp-product__accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="fp-product__accordion-panel" id="fp-acc-ingr" hidden>
            <div class="fp-product__accordion-body rte">{{ section.settings.ingredients_content }}</div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.how_to_use_content != blank -%}
        <div class="fp-product__accordion">
          <button class="fp-product__accordion-btn" type="button" aria-expanded="false" aria-controls="fp-acc-htu">
            <span class="fp-product__accordion-title">{{ section.settings.how_to_use_label }}</span>
            <svg class="fp-product__accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="fp-product__accordion-panel" id="fp-acc-htu" hidden>
            <div class="fp-product__accordion-body rte">{{ section.settings.how_to_use_content }}</div>
          </div>
        </div>
      {%- endif -%}

      <div class="fp-product__accordion">
        <button class="fp-product__accordion-btn" type="button" aria-expanded="true" aria-controls="fp-acc-info">
          <span class="fp-product__accordion-title">{{ section.settings.additional_info_label }}</span>
          <svg class="fp-product__accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="fp-product__accordion-panel" id="fp-acc-info">
          <div class="fp-product__accordion-body">
            <div class="fp-product__info-grid">
              {%- if product.metafields.custom.mrp != blank -%}
                <div class="fp-product__info-cell">
                  <strong>Price</strong>
                  <span>MRP ₹{{ product.metafields.custom.mrp }} inclusive of all taxes</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.best_before != blank -%}
                <div class="fp-product__info-cell">
                  <strong>Best Before</strong>
                  <span>{{ product.metafields.custom.best_before }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.packed_by != blank -%}
                <div class="fp-product__info-cell">
                  <strong>Packed By</strong>
                  <span>{{ product.metafields.custom.packed_by }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.marketed_by != blank -%}
                <div class="fp-product__info-cell">
                  <strong>Marketed By</strong>
                  <span>{{ product.metafields.custom.marketed_by }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.country_of_origin != blank -%}
                <div class="fp-product__info-cell">
                  <strong>Country of Origin</strong>
                  <span>{{ product.metafields.custom.country_of_origin }}</span>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- ─── Combo offers ────────────────────────────────────────── -->
    {%- assign combo_blocks = section.blocks | where: 'type', 'combo_item' -%}
    {%- if combo_blocks.size > 0 -%}
      <div class="fp-product__combos">
        <h2 class="fp-product__combos-hd">{{ section.settings.combo_heading }}</h2>
        <div class="fp-product__combos-grid">
          {%- for block in combo_blocks -%}
            {%- assign cb_product = block.settings.product -%}
            {%- assign cb_variant = cb_product.selected_or_first_available_variant -%}
            <div class="fp-product__combo-card" {{ block.shopify_attributes }}>
              {%- if block.settings.combo_badge != blank -%}
                <div class="fp-product__combo-badge">{{ block.settings.combo_badge }}</div>
              {%- endif -%}
              <div class="fp-product__combo-imgs">
                <div class="fp-product__combo-img-wrap">
                  {%- if product.featured_image -%}
                    {%- assign cb_main_alt = product.title | escape -%}
                    {{ product.featured_image | image_url: width: 280 | image_tag: loading: 'lazy', class: 'fp-product__combo-img', alt: cb_main_alt }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'fp-product__combo-img' }}
                  {%- endif -%}
                  <p class="fp-product__combo-img-label">{{ product.title | truncatewords: 4 }}</p>
                </div>
                <span class="fp-product__combo-plus" aria-hidden="true">+</span>
                <div class="fp-product__combo-img-wrap">
                  {%- if cb_product != blank and cb_product.featured_image -%}
                    {%- assign cb_pair_alt = cb_product.title | escape -%}
                    {{ cb_product.featured_image | image_url: width: 280 | image_tag: loading: 'lazy', class: 'fp-product__combo-img', alt: cb_pair_alt }}
                  {%- else -%}
                    {{ 'product-2' | placeholder_svg_tag: 'fp-product__combo-img' }}
                  {%- endif -%}
                  {%- if cb_product != blank -%}
                    <p class="fp-product__combo-img-label">{{ cb_product.title | truncatewords: 4 }}</p>
                  {%- endif -%}
                </div>
              </div>
              <div class="fp-product__combo-body">
                {%- if block.settings.combo_label != blank -%}
                  <span class="fp-product__combo-tag">{{ block.settings.combo_label }}</span>
                {%- endif -%}
                {%- if cb_product != blank -%}
                  <div class="fp-product__combo-prices">
                    {%- assign cb_total = current_variant.price | plus: cb_variant.price -%}
                    <span class="fp-product__combo-total">{{ cb_total | money }}</span>
                    {%- if block.settings.combo_savings != blank -%}
                      <span class="fp-product__combo-save">{{ block.settings.combo_savings }}</span>
                    {%- endif -%}
                  </div>
                  <button type="button" class="faiza-btn faiza-btn--gold fp-product__combo-cta" data-main-id="{{ current_variant.id }}" data-combo-id="{{ cb_variant.id }}">{{ 'products.product.add_combo' | t }}</button>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <!-- ─── Product banners ─────────────────────────────────── -->

    <div class="fp-product__feature-banners">

      {%- assign banner_1 = product.metafields.custom.banner_1.value -%}
      {%- assign banner_2 = product.metafields.custom.banner_2.value -%}
      {%- assign banner_3 = product.metafields.custom.banner_3.value -%}
      {%- assign banner_4 = product.metafields.custom.banner_4.value -%}
      {%- assign banner_5 = product.metafields.custom.banner_5.value -%}

      {%- if banner_1 != blank -%}
        <div class="fp-product__feature-banner">
          {{ banner_1 | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'fp-product__feature-banner-img', alt: product.title }}
        </div>
      {%- endif -%}

      {%- if banner_2 != blank -%}
        <div class="fp-product__feature-banner">
          {{ banner_2 | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'fp-product__feature-banner-img', alt: product.title }}
        </div>
      {%- endif -%}

      {%- if banner_3 != blank -%}
        <div class="fp-product__feature-banner">
          {{ banner_3 | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'fp-product__feature-banner-img', alt: product.title }}
        </div>
      {%- endif -%}

      {%- if banner_4 != blank -%}
        <div class="fp-product__feature-banner">
          {{ banner_4 | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'fp-product__feature-banner-img', alt: product.title }}
        </div>
      {%- endif -%}

      {%- if banner_5 != blank -%}
        <div class="fp-product__feature-banner">
          {{ banner_5 | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'fp-product__feature-banner-img', alt: product.title }}
        </div>
      {%- endif -%}

    </div>

    <!-- ─── FAQ ──────────────────────────────────────────────── -->
    {%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
    {%- if faq_blocks.size > 0 -%}
      <div class="fp-product__faq">
        <h2 class="fp-product__faq-hd">{{ section.settings.faq_heading }}</h2>
        <div class="fp-product__faq-list" id="fp-faq">
          {%- for block in faq_blocks -%}
            <div class="fp-product__faq-item" {{ block.shopify_attributes }}>
              <button class="fp-product__faq-q" type="button" aria-expanded="false">
                <span>{{ block.settings.question }}</span>
                <svg class="fp-product__faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="fp-product__faq-a" hidden>
                <div class="fp-product__faq-a-inner">{{ block.settings.answer }}</div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <!-- ─── Related products slider ────────────────────────────── -->
    {%- if section.settings.show_related -%}
      {%- assign fp_rel_col = collection | default: section.settings.related_collection -%}
      {%- if fp_rel_col != blank -%}
        <div class="fp-product__related">
          <h2 class="fp-product__related-hd">{{ section.settings.related_heading }}</h2>
          <div class="fp-product__rel-slider" id="fp-rel-slider">
            <button class="fp-product__rel-arrow fp-product__rel-arrow--prev" type="button" id="fp-rel-prev" aria-label="Previous">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <div class="fp-product__rel-track-wrap">
              <div class="fp-product__related-grid" id="fp-rel-track">
                {%- assign fp_rel_count = section.settings.related_count -%}
                {%- for rel_prod in fp_rel_col.products limit: fp_rel_count -%}
                  {%- unless rel_prod.handle == product.handle -%}
                    <a href="{{ rel_prod.url }}" class="fp-product__rel-card">
                      <div class="fp-product__rel-img-wrap">
                        {%- if rel_prod.featured_image -%}
                          {%- assign rel_img_alt = rel_prod.featured_image.alt | default: rel_prod.title | escape -%}
                          {{ rel_prod.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'fp-product__rel-img', alt: rel_img_alt }}
                        {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'fp-product__rel-img' }}
                        {%- endif -%}
                        {%- if rel_prod.compare_at_price > rel_prod.price -%}
                          {%- assign rel_pct = rel_prod.compare_at_price | minus: rel_prod.price | times: 100 | divided_by: rel_prod.compare_at_price -%}
                          <span class="fp-product__rel-badge">{{ rel_pct }}% {{ 'general.off' | t }}</span>
                        {%- endif -%}
                      </div>
                      <div class="fp-product__rel-info">
                        <p class="fp-product__rel-title">{{ rel_prod.title }}</p>
                        <div class="fp-product__rel-prices">
                          <span class="fp-product__rel-price">{{ rel_prod.price | money }}</span>
                          {%- if rel_prod.compare_at_price > rel_prod.price -%}
                            <span class="fp-product__rel-compare">{{ rel_prod.compare_at_price | money }}</span>
                          {%- endif -%}
                        </div>
                      </div>
                    </a>
                  {%- endunless -%}
                {%- endfor -%}
              </div>
            </div>
            <button class="fp-product__rel-arrow fp-product__rel-arrow--next" type="button" id="fp-rel-next" aria-label="Next">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

  </div><!-- /fp-product__wrap -->
</div><!-- /fp-product -->

{% stylesheet %}

/* ── Product page wrapper ──────────────────────────────── */
.fp-product {
  padding-top: var(--faiza-sp-6);
  padding-bottom: var(--faiza-sp-20);
}

/* ── 2-column layout ───────────────────────────────────── */
.fp-product__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--faiza-sp-8);
  margin-bottom: var(--faiza-sp-16);
}

@media screen and (min-width: 990px) {
  .fp-product__layout {
    grid-template-columns: 44fr 56fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
}

/* ── Gallery ───────────────────────────────────────────── */
.fp-product__gallery {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

@media screen and (min-width: 990px) {
  .fp-product__gallery {
    position: sticky;
    top: 100px;
  }
}

/* Stage */
.fp-product__stage {
  position: relative;
  background-color: #f0ece6;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  border-radius: 12px;
}

.fp-product__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.35s ease;
  pointer-events: none;
}

.fp-product__slide--active {
  opacity: 1;
  pointer-events: auto;
}

.fp-product__stage-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
}

/* Stage badge */
.fp-product__stage-badge {
  position: absolute;
  top: 14px;
  right: 14px;
  background-color: #1a0a0a;
  color: #c9a96e;
  font-family: var(--faiza-font-body);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 5px 12px;
  border-radius: 999px;
  z-index: 3;
  pointer-events: none;
  display: flex;
  align-items: center;
  gap: 5px;
}

.fp-product__stage-badge--hidden { display: none; }

/* Arrows */
.fp-product__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 2.25rem;
  height: 2.25rem;
  background: rgba(255, 255, 255, 0.9);
  border: none;
  border-radius: 4px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
  color: #1a1614;
  transition: background-color 0.2s;
}

.fp-product__arrow--prev { left: 10px; }
.fp-product__arrow--next { right: 10px; }
.fp-product__arrow:hover { background-color: #ffffff; }
.fp-product__arrow svg { width: 1.125rem; height: 1.125rem; }

/* Thumbnails — horizontal strip below stage */
.fp-product__thumbs {
  display: flex;
  flex-direction: row;
  gap: 8px;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 2px;
}

.fp-product__thumbs::-webkit-scrollbar { display: none; }

.fp-product__thumb {
  width: 68px;
  height: 68px;
  flex-shrink: 0;
  border: 2px solid transparent;
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  background: #f0ece6;
  padding: 0;
  transition: border-color 0.2s;
}

.fp-product__thumb--active { border-color: #c9a96e; }
.fp-product__thumb:hover:not(.fp-product__thumb--active) { border-color: rgba(201, 169, 110, 0.5); }

.fp-product__thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Product info ──────────────────────────────────────── */
.fp-product__info {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* Breadcrumb */
.fp-product__bc {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 5px;
  font-size: 0.8125rem;
}

.fp-product__bc-link {
  color: #6b7280;
  text-decoration: none;
  transition: color 0.2s;
}

.fp-product__bc-link:hover { color: #c9a96e; }
.fp-product__bc-sep { color: #9ca3af; }
.fp-product__bc-cur { color: #374151; }

/* Rating row */
.fp-product__rating-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.fp-product__rating-star-single {
  width: 15px;
  height: 15px;
  fill: #f59e0b;
  color: #f59e0b;
  flex-shrink: 0;
}

.fp-product__rating-num {
  font-size: 0.875rem;
  font-weight: 600;
  color: #1a1614;
}

.fp-product__rating-sep {
  color: #d1d5db;
  font-size: 0.875rem;
}

.fp-product__rating-txt {
  font-size: 0.875rem;
  color: #6b7280;
  border-bottom: 1px solid #d1d5db;
}

.fp-product__units-sold {
  font-size: 0.875rem;
  color: #374151;
  font-weight: 500;
}

/* Title */
.fp-product__title {
  font-family: var(--faiza-font-display);
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 400;
  line-height: 1.25;
  letter-spacing: -0.01em;
  color: #1a1614;
  margin: 0;
}

/* Tags */
.fp-product__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.fp-product__tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  background: #3d1a12;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 500;
  color: #fff;
  letter-spacing: 0.02em;
}

.fp-product__tag-check {
  width: 11px;
  height: 11px;
  flex-shrink: 0;
  color: #c9a96e;
}

/* Price */
.fp-product__price-block { display: flex; flex-direction: column; gap: 4px; }

.fp-product__prices {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px;
}

.fp-product__price {
  font-family: var(--faiza-font-display);
  font-size: clamp(1.375rem, 2.5vw, 1.75rem);
  font-weight: 500;
  color: #1a1614;
}

.fp-product__price--sale { color: #1a1614; }

.fp-product__compare {
  font-size: 1rem;
  color: #9ca3af;
  text-decoration: line-through;
}

.fp-product__compare--hidden,
.fp-product__save--hidden { display: none; }

.fp-product__save {
  display: inline-block;
  background: #16a34a;
  color: #ffffff;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 4px;
  letter-spacing: 0.02em;
}

.fp-product__tax-note {
  font-size: 0.8125rem;
  color: #6b7280;
  margin: 0;
}

/* ── Collection product strip ────────────────────────────── */
.fp-cstrip {
  padding: 0;
  background: transparent;
}

.fp-cstrip__hd {
  font-size: 0.8125rem;
  font-weight: 500;
  color: #6b7280;
  margin: 0 0 10px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  gap: 4px;
}

.fp-cstrip__hd strong {
  color: #1a1a1a;
  font-weight: 700;
}

.fp-cstrip__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  max-height: 520px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(201, 169, 110, 0.4) transparent;
}

.fp-cstrip__grid::-webkit-scrollbar { width: 3px; }
.fp-cstrip__grid::-webkit-scrollbar-track { background: transparent; }
.fp-cstrip__grid::-webkit-scrollbar-thumb { background: rgba(201, 169, 110, 0.45); border-radius: 2px; }

.fp-cstrip__card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border: 2px solid transparent;
  border-radius: 8px;
  overflow: hidden;
  background: transparent;
  transition: border-color 0.2s, transform 0.18s;
}

.fp-cstrip__card:hover:not(.fp-cstrip__card--active) {
  border-color: rgba(201, 169, 110, 0.4);
  transform: translateY(-2px);
}

.fp-cstrip__card--active {
  border: 2px solid #c9a96e;
}

.fp-cstrip__img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: transparent;
  flex-shrink: 0;
  border-radius: 6px;
}

.fp-cstrip__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.fp-cstrip__body {
  padding: 6px 4px 4px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.fp-cstrip__name {
  font-size: 11px;
  line-height: 1.3;
  color: #374151;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: center;
}

.fp-cstrip__prices {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
}

.fp-cstrip__price {
  font-size: 12px;
  font-weight: 700;
  color: #111827;
}

.fp-cstrip__compare {
  font-size: 10px;
  color: #9ca3af;
  text-decoration: line-through;
}

@media (max-width: 990px) {
  .fp-cstrip__grid {
    grid-template-columns: repeat(3, 1fr);
    max-height: none;
  }
}

@media (max-width: 480px) {
  .fp-cstrip__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Form */
.fp-product__form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* Option groups */
.fp-product__opt-group { display: flex; flex-direction: column; gap: 7px; }

.fp-product__opt-hd {
  display: flex;
  align-items: center;
  gap: 8px;
}

.fp-product__opt-name {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #374151;
}

.fp-product__opt-val {
  font-size: 0.875rem;
  color: #6b7280;
}

.fp-product__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}

.fp-product__swatch {
  min-width: 2.5rem;
  padding: 7px 13px;
  border: 1.5px solid rgba(0,0,0,0.14);
  background: transparent;
  font-size: 0.875rem;
  color: #1a1614;
  cursor: pointer;
  border-radius: 6px;
  transition: border-color 0.2s, background-color 0.2s;
  line-height: 1;
}

.fp-product__swatch--on {
  border-color: #c9a96e;
  background-color: rgba(201, 169, 110, 0.08);
  font-weight: 600;
}

.fp-product__swatch:hover:not(.fp-product__swatch--on) {
  border-color: rgba(201, 169, 110, 0.5);
}

/* Qty + CTA row */
.fp-product__cta-row {
  display: flex;
  align-items: stretch;
  gap: 10px;
}

.fp-product__qty {
  display: flex;
  align-items: stretch;
  border: 1.5px solid rgba(201, 169, 110, 0.45);
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
}

.fp-product__qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.375rem;
  min-height: 46px;
  background: none;
  border: none;
  cursor: pointer;
  color: #1a1614;
  font-size: 1.125rem;
  font-weight: 300;
  transition: background-color 0.18s;
  flex-shrink: 0;
}

.fp-product__qty-btn:hover { background-color: rgba(201, 169, 110, 0.1); }

.fp-product__qty-input {
  width: 2.5rem;
  border: none;
  border-left: 1px solid rgba(201, 169, 110, 0.3);
  border-right: 1px solid rgba(201, 169, 110, 0.3);
  text-align: center;
  font-size: 0.9375rem;
  font-weight: 600;
  color: #1a1614;
  background: transparent;
  -moz-appearance: textfield;
}

.fp-product__qty-input::-webkit-outer-spin-button,
.fp-product__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

.fp-product__add-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 18px;
  background: linear-gradient(135deg, #d4a83e 0%, #c9a96e 45%, #b8872a 100%);
  border: none;
  border-radius: 8px;
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  cursor: pointer;
  transition: filter 0.2s;
  min-height: 46px;
}

.fp-product__add-btn:hover:not(:disabled) { filter: brightness(1.08); }
.fp-product__add-btn:disabled { opacity: 0.55; cursor: not-allowed; }

.fp-product__add-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.fp-product__cta-secondary { margin-top: 8px; }
.fp-product__cta-secondary .fp-product__buy-btn { width: 100%; }

/* Delivery */
.fp-product__delivery {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  background: #f9f5f0;
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: 8px;
  font-size: 0.875rem;
  color: #374151;
}

.fp-product__delivery-icon {
  width: 1.375rem;
  height: 1.375rem;
  flex-shrink: 0;
  color: #c9a96e;
}

/* ── Trust badges ──────────────────────────────────────── */
.fp-product__trust {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background-color: rgba(0,0,0,0.08);
  border: 1px solid rgba(0,0,0,0.08);
  margin-bottom: var(--faiza-sp-16);
}

@media screen and (min-width: 600px) {
  .fp-product__trust { grid-template-columns: repeat(4, 1fr); }
}

.fp-product__trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 28px 16px;
  background: var(--faiza-bg-base);
  text-align: center;
}

.fp-product__trust-icon {
  width: 2.5rem;
  height: 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--faiza-gold);
}

.fp-product__trust-icon svg { width: 1.875rem; height: 1.875rem; }

.fp-product__trust-label {
  font-size: var(--faiza-size-base);
  font-weight: 500;
  color: var(--faiza-text-1);
  line-height: var(--faiza-leading-snug);
}

/* ── Accordions ────────────────────────────────────────── */
.fp-product__accordions {
  margin-bottom: var(--faiza-sp-16);
}

.fp-product__accordion {
  border-top: 1.5px solid var(--faiza-gold);
}

.fp-product__accordion:last-child {
  border-bottom: 1.5px solid var(--faiza-gold);
}

.fp-product__accordion-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 24px 52px;
  background: none;
  border: none;
  cursor: pointer;
  transition: background-color 0.2s;
}

.fp-product__accordion-btn:hover {
  background-color: rgba(201, 169, 110, 0.04);
}

.fp-product__accordion-title {
  font-family: var(--faiza-font-display);
  font-size: clamp(1.125rem, 2vw, 1.5rem);
  font-weight: 400;
  color: var(--faiza-text-1);
  letter-spacing: var(--faiza-tracking-tight);
}

.fp-product__accordion-chevron {
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  width: 1.25rem;
  height: 1.25rem;
  color: var(--faiza-text-3);
  transition: transform 0.28s ease;
}

.fp-product__accordion-btn[aria-expanded="true"] .fp-product__accordion-chevron {
  transform: translateY(-50%) rotate(180deg);
}

.fp-product__accordion-panel {
  padding: 4px 40px 36px;
}

@media screen and (max-width: 749px) {
  .fp-product__accordion-btn {
    padding: 20px 44px 20px 16px;
    justify-content: flex-start;
  }
  .fp-product__accordion-panel { padding: 4px 16px 28px; }
}

.fp-product__accordion-body {
  font-size: var(--faiza-size-md);
  line-height: var(--faiza-leading-loose);
  color: var(--faiza-text-2);
}

.fp-product__accordion-body p { margin-top: 0; margin-bottom: 1em; }
.fp-product__accordion-body ul,
.fp-product__accordion-body ol { padding-left: 1.5em; margin-bottom: 1em; }
.fp-product__accordion-body li { margin-bottom: 0.375em; }
.fp-product__accordion-body h2,
.fp-product__accordion-body h3,
.fp-product__accordion-body h4 {
  font-family: var(--faiza-font-display);
  color: var(--faiza-cream);
  margin-bottom: 0.5em;
}

/* Additional info 2-column grid */
.fp-product__info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px 48px;
  padding: 8px 0 8px;
}

.fp-product__info-cell {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.fp-product__info-cell strong {
  display: block;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--faiza-text-1);
}

.fp-product__info-cell span {
  font-size: var(--faiza-size-base);
  color: var(--faiza-text-2);
  line-height: 1.55;
}

@media screen and (max-width: 599px) {
  .fp-product__info-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}

/* ── FAQ ───────────────────────────────────────────────── */
.fp-product__faq {
  padding-top: var(--faiza-sp-12);
  padding-bottom: var(--faiza-sp-12);
}

.fp-product__faq-hd {
