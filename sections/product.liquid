  align-items: center;
  gap: 8px;
}

.fp-product__rel-track-wrap { flex: 1; overflow: hidden; }

.fp-product__related-grid {
  display: flex;
  gap: var(--faiza-sp-4);
  transition: transform 0.35s ease;
  will-change: transform;
}

.fp-product__rel-card {
