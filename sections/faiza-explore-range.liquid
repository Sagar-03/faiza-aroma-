<section class="faiza-explore-range full-width">
  <div class="faiza-explore-range__wrapper">

    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2500
        | image_tag:
          class: 'faiza-explore-range__image',
          loading: 'lazy'
      }}
    {% endif %}

    <div class="faiza-explore-range__content">

      {% if section.settings.heading != blank %}
        <h2 class="faiza-explore-range__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="faiza-explore-range__button"
        >
          {{ section.settings.button_text }}
        </a>
      {% endif %}

    </div>

  </div>
</section>

<style>
  .faiza-explore-range-section {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
  }

  .shopify-section:has(.faiza-explore-range) {
    padding: 0 !important;
    margin: 0 !important;
    gap: 0 !important;
  }

.faiza-explore-range{
  padding: 20px 20px;
  background:#f7f5f2;
}

.faiza-explore-range__wrapper{
  position:relative;
  max-width:1400px;
  margin:auto;
  overflow:hidden;
  border-radius:28px;
}

.faiza-explore-range__image{
  width:100%;
  display:block;
  border-radius:28px;
}

.faiza-explore-range__content{
  position:absolute;
  top:50%;
  left:60px;
  transform:translateY(-50%);
  max-width:420px;
}

.faiza-explore-range__heading{
  color:#f3dfb4;
  font-size:clamp(42px,5vw,78px);
  line-height:1.1;
  font-weight:400;
  margin-bottom:40px;
  font-family: serif;
}

.faiza-explore-range__button{
  display:inline-flex;
  align-items:center;
  gap:10px;
  color:#fff;
  text-decoration:none;
  font-size:20px;
  font-weight:500;
  transition:.3s;
}

.faiza-explore-range__button:hover{
  transform:translateX(6px);
}

.faiza-explore-range__button::after{
  content:"›";
  width:28px;
  height:28px;
  border-radius:50%;
  background:#fff;
  color:#000;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:18px;
}

@media(max-width:768px){

  .faiza-explore-range{
    padding:20px 12px;
  }

  .faiza-explore-range__wrapper{
    border-radius:20px;
  }

  .faiza-explore-range__content{
    left:20px;
    top:40px;
    transform:none;
    max-width:220px;
  }

  .faiza-explore-range__heading{
    font-size:32px;
    margin-bottom:20px;
  }

  .faiza-explore-range__button{
    font-size:15px;
  }
}
</style>

{% schema %}
{
  "name": "Faiza Explore Range",
  "class": "faiza-explore-range-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "The fragrance larger than life"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore the range"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Faiza Explore Range"
    }
  ]
}
{% endschema %}