<div
  class="faiza-cat full-width"
  style="--sec-pad: {{ section.settings.section_spacing }}px;"
>
  <div class="faiza-cat__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="faiza-cat__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="faiza-cat__eyebrow">
            <span class="faiza-cat__rule" aria-hidden="true"></span>
            {{- section.settings.eyebrow | escape -}}
            <span class="faiza-cat__rule" aria-hidden="true"></span>
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="faiza-cat__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="faiza-cat__sub">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <ul class="faiza-cat__grid" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign cat_url = block.settings.collection.url
          if cat_url == blank
            assign cat_url = block.settings.collection_url
          endif
          if cat_url == blank and block.settings.title != blank
            assign cat_handle = block.settings.title | handleize
            assign cat_url = routes.root_url | append: 'collections/' | append: cat_handle
          endif
          assign cat_url = cat_url | default: routes.collections_url
        -%}
        <li class="faiza-cat__item" {{ block.shopify_attributes }}>
          <a
            class="faiza-cat__link"
            href="{{ cat_url }}"
          >
            <div class="faiza-cat__card">
              <div class="faiza-cat__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '200, 300, 400, 600',
                      sizes: '(min-width: 990px) 220px, (min-width: 750px) calc(33vw - 2.5rem), calc(50vw - 2.5rem)',
                      class: 'faiza-cat__img',
                      alt: block.settings.image.alt | default: block.settings.title | escape
                  }}
                {%- else -%}
                  <div class="faiza-cat__media-empty">
                    {{ 'collection-1' | placeholder_svg_tag: 'faiza-cat__placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>
            </div>

            <div class="faiza-cat__caption">
              {%- if block.settings.title != blank -%}
                <span class="faiza-cat__name">{{ block.settings.title | escape }}</span>
              {%- endif -%}
              <span class="faiza-cat__cta-text" aria-hidden="true">
                {{- 'sections.faiza_cat.shop_now' | t | default: 'Shop Now' -}}
              </span>
            </div>
          </a>
        </li>

      {%- else -%}
        {%- for i in (1..6) -%}
          <li class="faiza-cat__item faiza-cat__item--ph">
            <div class="faiza-cat__link">
              <div class="faiza-cat__card">
                <div class="faiza-cat__media">
                  <div class="faiza-cat__media-empty">
                    {{ 'collection-1' | placeholder_svg_tag: 'faiza-cat__placeholder-svg' }}
                  </div>
                </div>
              </div>
              <div class="faiza-cat__caption">
                <span class="faiza-cat__name">{{ 'sections.faiza_cat.category' | t | default: 'Category' }} {{ forloop.index }}</span>
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

{% stylesheet %}
  /* ─── Section ─── */
  .faiza-cat {
    padding: var(--sec-pad, 24px) 0;
    background-color: #ffffff;
  }

  .faiza-cat__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ─── Header ─── */
  .faiza-cat__header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .faiza-cat__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 1.25rem;
  }

  .faiza-cat__rule {
    display: block;
    flex-shrink: 0;
    width: 2.25rem;
    height: 1px;
    background-color: #c9a96e;
  }

  .faiza-cat__heading {
    font-family: var(--font-heading-family, serif);
    font-size: clamp(1.875rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #1a1614;
    margin: 0 0 0.875rem;
  }

  .faiza-cat__sub {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp(0.875rem, 1.2vw, 0.9375rem);
    font-weight: 300;
    line-height: 1.75;
    letter-spacing: 0.03em;
    color: rgba(26, 22, 20, 0.55);
    margin: 0 auto;
    max-width: 50ch;
  }

  /* ─── Grid ─── */
  .faiza-cat__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ─── Item / Link ─── */
  .faiza-cat__item { display: block; }

  .faiza-cat__link {
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  /* ─── Transparent card ─── */
  .faiza-cat__card {
    position: relative;
    width: 100%;
    padding-bottom: 185%;
    background: rgba(255, 255, 255, 0.45);
   
    border-radius: 4px;
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .faiza-cat__link:hover .faiza-cat__card,
  .faiza-cat__link:focus-visible .faiza-cat__card {
     box-shadow: none;
  transform: translateY(-5px);
  }

  /* ─── Media ─── */
  .faiza-cat__media {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 1rem;
  }

  .faiza-cat__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .faiza-cat__link:hover .faiza-cat__img,
  .faiza-cat__link:focus-visible .faiza-cat__img {
    transform: scale(1.05);
  }

  .faiza-cat__media-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .faiza-cat__placeholder-svg {
    width: 55%;
    height: 55%;
    fill: rgba(201, 169, 110, 0.25);
  }

  /* ─── Caption ─── */
  .faiza-cat__caption {
    margin-top: 0.875rem;
    text-align: center;
    padding: 0 0.25rem;
    min-height: 2.75rem;
  }

  .faiza-cat__name {
    display: block;
    font-family: var(--font-heading-family, serif);
    font-size: clamp(0.8125rem, 1.1vw, 0.9375rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: #1a1614;
    margin-bottom: 0.3rem;
    transition: color 0.3s ease;
  }

  .faiza-cat__link:hover .faiza-cat__name,
  .faiza-cat__link:focus-visible .faiza-cat__name {
    color: #c9a96e;
  }

  .faiza-cat__cta-text {
    display: block;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.5625rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .faiza-cat__link:hover .faiza-cat__cta-text,
  .faiza-cat__link:focus-visible .faiza-cat__cta-text {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Tablet: 3 columns ─── */
  @media screen and (min-width: 750px) {
    .faiza-cat__inner { padding: 0 2.5rem; }
    .faiza-cat__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  /* ─── Desktop: 6 columns ─── */
  @media screen and (min-width: 990px) {
    .faiza-cat__inner { padding: 0 3rem; }
    .faiza-cat__grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (min-width: 1440px) {
    .faiza-cat__inner { padding: 0 4.5rem; }
  }

  /* ─── Focus ─── */
  .faiza-cat__link:focus-visible {
    outline: 2px solid #c9a96e;
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .faiza-cat__card,
    .faiza-cat__img,
    .faiza-cat__name,
    .faiza-cat__cta-text { transition: none; }

    .faiza-cat__link:hover .faiza-cat__card,
    .faiza-cat__link:focus-visible .faiza-cat__card { transform: none; }

    .faiza-cat__link:hover .faiza-cat__img,
    .faiza-cat__link:focus-visible .faiza-cat__img { transform: none; }

    .faiza-cat__link:hover .faiza-cat__cta-text,
    .faiza-cat__link:focus-visible .faiza-cat__cta-text {
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Faiza Category Grid",
  "tag": "section",
  "class": "faiza-cat-section",
  "settings": [
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Section spacing",
      "min": 8,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Explore Our Range"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop By Category"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Category Name"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Custom link (used only if no collection selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Faiza Category Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Oud" } },
        { "type": "category", "settings": { "title": "Floral" } },
        { "type": "category", "settings": { "title": "Woody" } },
        { "type": "category", "settings": { "title": "Oriental" } },
        { "type": "category", "settings": { "title": "Citrus" } },
        { "type": "category", "settings": { "title": "Musk" } }
      ]
    }
  ]
}
{% endschema %}
