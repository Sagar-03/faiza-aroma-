{%- liquid
  assign arch_id = 'faiza-arch-' | append: section.id
-%}

<svg width="0" height="0" focusable="false" style="position:absolute;overflow:hidden" aria-hidden="true">
  <defs>
    <clipPath id="{{ arch_id }}" clipPathUnits="objectBoundingBox">
      <path d="M 0,1 L 0,0.42 C 0,0.08 0.12,0 0.5,0 C 0.88,0 1,0.08 1,0.42 L 1,1 Z"/>
    </clipPath>
  </defs>
</svg>

<div
  class="faiza-cat full-width"
  style="--sec-pad: {{ section.settings.section_spacing }}px;"
>
  <div class="faiza-cat__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="faiza-cat__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="faiza-cat__eyebrow">
            <span class="faiza-cat__rule" aria-hidden="true"></span>
            {{- section.settings.eyebrow | escape -}}
            <span class="faiza-cat__rule" aria-hidden="true"></span>
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="faiza-cat__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="faiza-cat__sub">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <ul class="faiza-cat__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="faiza-cat__item" {{ block.shopify_attributes }}>
          <a
            class="faiza-cat__link"
            href="{{ block.settings.collection_url | default: routes.collections_url }}"
          >
            <div class="faiza-cat__frame">
              <svg
                class="faiza-cat__border-svg"
                viewBox="0 0 220 320"
                preserveAspectRatio="none"
                aria-hidden="true"
                focusable="false"
              >
                <defs>
                  <linearGradient
                    id="faiza-g-{{ section.id }}-{{ forloop.index }}"
                    x1="0%" y1="0%" x2="100%" y2="100%"
                  >
                    <stop offset="0%"   stop-color="#5c3d10"/>
                    <stop offset="28%"  stop-color="#c9a96e"/>
                    <stop offset="50%"  stop-color="#f0d090"/>
                    <stop offset="72%"  stop-color="#c9a96e"/>
                    <stop offset="100%" stop-color="#5c3d10"/>
                  </linearGradient>
                </defs>
                <path
                  d="M 1.5,318.5 L 1.5,134.4 C 1.5,27 40,1.5 110,1.5 C 180,1.5 218.5,27 218.5,134.4 L 218.5,318.5 Z"
                  fill="none"
                  stroke="url(#faiza-g-{{ section.id }}-{{ forloop.index }})"
                  stroke-width="1.5"
                  vector-effect="non-scaling-stroke"
                />
              </svg>

              <div
                class="faiza-cat__card"
                style="clip-path: url(#{{ arch_id }});"
              >
                <div class="faiza-cat__pattern" aria-hidden="true"></div>

                <div class="faiza-cat__media">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        widths: '200, 300, 400, 600',
                        sizes: '(min-width: 990px) 220px, (min-width: 750px) calc(33vw - 2.5rem), calc(50vw - 2.5rem)',
                        class: 'faiza-cat__img',
                        alt: block.settings.image.alt | default: block.settings.title | escape
                    }}
                  {%- else -%}
                    <div class="faiza-cat__media-empty">
                      {{ 'collection-1' | placeholder_svg_tag: 'faiza-cat__placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>

                <div class="faiza-cat__veil" aria-hidden="true"></div>
              </div>
            </div>

            <div class="faiza-cat__caption">
              {%- if block.settings.title != blank -%}
                <span class="faiza-cat__name">{{ block.settings.title | escape }}</span>
              {%- endif -%}
              <span class="faiza-cat__cta-text" aria-hidden="true">
                {{- 'sections.faiza_cat.shop_now' | t | default: 'Shop Now' -}}
              </span>
            </div>
          </a>
        </li>

      {%- else -%}
        {%- for i in (1..6) -%}
          <li class="faiza-cat__item faiza-cat__item--ph">
            <div class="faiza-cat__link">
              <div class="faiza-cat__frame">
                <svg
                  class="faiza-cat__border-svg"
                  viewBox="0 0 220 320"
                  preserveAspectRatio="none"
                  aria-hidden="true"
                  focusable="false"
                >
                  <defs>
                    <linearGradient
                      id="faiza-g-ph-{{ section.id }}-{{ forloop.index }}"
                      x1="0%" y1="0%" x2="100%" y2="100%"
                    >
                      <stop offset="0%"   stop-color="#5c3d10"/>
                      <stop offset="50%"  stop-color="#f0d090"/>
                      <stop offset="100%" stop-color="#5c3d10"/>
                    </linearGradient>
                  </defs>
                  <path
                    d="M 1.5,318.5 L 1.5,134.4 C 1.5,27 40,1.5 110,1.5 C 180,1.5 218.5,27 218.5,134.4 L 218.5,318.5 Z"
                    fill="none"
                    stroke="url(#faiza-g-ph-{{ section.id }}-{{ forloop.index }})"
                    stroke-width="1.5"
                    vector-effect="non-scaling-stroke"
                  />
                </svg>
                <div
                  class="faiza-cat__card"
                  style="clip-path: url(#{{ arch_id }});"
                >
                  <div class="faiza-cat__pattern" aria-hidden="true"></div>
                  <div class="faiza-cat__media">
                    <div class="faiza-cat__media-empty">
                      {{ 'collection-1' | placeholder_svg_tag: 'faiza-cat__placeholder-svg' }}
                    </div>
                  </div>
                  <div class="faiza-cat__veil" aria-hidden="true"></div>
                </div>
              </div>
              <div class="faiza-cat__caption">
                <span class="faiza-cat__name">{{ 'sections.faiza_cat.category' | t | default: 'Category' }} {{ forloop.index }}</span>
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

{% stylesheet %}
  /* ─── Section ─── */
  .faiza-cat {
    padding: var(--sec-pad, 96px) 0;
    background-color: #faf8f5;
    overflow: hidden;
  }

  .faiza-cat__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ─── Header ─── */
  .faiza-cat__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .faiza-cat__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 1.25rem;
  }

  .faiza-cat__rule {
    display: block;
    flex-shrink: 0;
    width: 2.25rem;
    height: 1px;
    background-color: #c9a96e;
  }

  .faiza-cat__heading {
    font-family: var(--font-heading-family, serif);
    font-size: clamp(1.875rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #1a1614;
    margin: 0 0 0.875rem;
  }

  .faiza-cat__sub {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp(0.875rem, 1.2vw, 0.9375rem);
    font-weight: 300;
    line-height: 1.75;
    letter-spacing: 0.03em;
    color: rgba(26, 22, 20, 0.55);
    margin: 0;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ─── Grid ─── */
  .faiza-cat__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ─── Item / Link ─── */
  .faiza-cat__item {
    display: block;
  }

  .faiza-cat__link {
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  /* ─── Arch frame ─── */
  .faiza-cat__frame {
    position: relative;
    width: 100%;
    padding-bottom: 145.45%; /* 320 / 220 */
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    filter: drop-shadow(0 6px 18px rgba(0, 0, 0, 0.14));
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 0.3s ease;
  }

  .faiza-cat__link:hover .faiza-cat__frame,
  .faiza-cat__link:focus-visible .faiza-cat__frame {
    transform: translateY(-7px);
    filter: drop-shadow(0 14px 28px rgba(0, 0, 0, 0.18))
            drop-shadow(0 0 20px rgba(201, 169, 110, 0.28));
  }

  /* ─── Gold SVG border ─── */
  .faiza-cat__border-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    pointer-events: none;
  }

  /* ─── Card (clipped to arch) ─── */
  .faiza-cat__card {
    position: absolute;
    inset: 2px;
    overflow: hidden;
    background-color: #ede9e3;
  }

  /* ─── Geometric luxury pattern ─── */
  .faiza-cat__pattern {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-color: #ede9e3;
    background-image:
      repeating-linear-gradient(
        45deg,
        rgba(201, 169, 110, 0.065) 0px,
        rgba(201, 169, 110, 0.065) 1px,
        transparent 1px,
        transparent 16px
      ),
      repeating-linear-gradient(
        -45deg,
        rgba(201, 169, 110, 0.065) 0px,
        rgba(201, 169, 110, 0.065) 1px,
        transparent 1px,
        transparent 16px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(201, 169, 110, 0.028) 0px,
        rgba(201, 169, 110, 0.028) 1px,
        transparent 1px,
        transparent 16px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(201, 169, 110, 0.028) 0px,
        rgba(201, 169, 110, 0.028) 1px,
        transparent 1px,
        transparent 16px
      );
  }

  /* ─── Media ─── */
  .faiza-cat__media {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .faiza-cat__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .faiza-cat__link:hover .faiza-cat__img,
  .faiza-cat__link:focus-visible .faiza-cat__img {
    transform: scale(1.08);
  }

  .faiza-cat__media-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #e8e4de;
  }

  .faiza-cat__placeholder-svg {
    width: 55%;
    height: 55%;
    fill: rgba(201, 169, 110, 0.18);
  }

  /* ─── Bottom gradient veil ─── */
  .faiza-cat__veil {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    z-index: 2;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.08) 55%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ─── Caption ─── */
  .faiza-cat__caption {
    margin-top: 0.875rem;
    text-align: center;
    padding: 0 0.25rem;
    min-height: 2.75rem;
  }

  .faiza-cat__name {
    display: block;
    font-family: var(--font-heading-family, serif);
    font-size: clamp(0.8125rem, 1.1vw, 0.9375rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: #1a1614;
    margin-bottom: 0.3rem;
    transition: color 0.3s ease;
  }

  .faiza-cat__link:hover .faiza-cat__name,
  .faiza-cat__link:focus-visible .faiza-cat__name {
    color: #c9a96e;
  }

  .faiza-cat__cta-text {
    display: block;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.5625rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a96e;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .faiza-cat__link:hover .faiza-cat__cta-text,
  .faiza-cat__link:focus-visible .faiza-cat__cta-text {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Tablet: 3 columns ─── */
  @media screen and (min-width: 750px) {
    .faiza-cat__inner {
      padding: 0 2.5rem;
    }

    .faiza-cat__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem 1.5rem;
    }
  }

  /* ─── Desktop: 6 columns ─── */
  @media screen and (min-width: 990px) {
    .faiza-cat__inner {
      padding: 0 3rem;
    }

    .faiza-cat__grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 2rem 1.25rem;
    }
  }

  @media screen and (min-width: 1440px) {
    .faiza-cat__inner {
      padding: 0 4.5rem;
    }
  }

  /* ─── Focus ─── */
  .faiza-cat__link:focus-visible {
    outline: 2px solid #c9a96e;
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .faiza-cat__frame {
      transition: none;
    }

    .faiza-cat__img {
      transition: none;
    }

    .faiza-cat__cta-text {
      transition: none;
    }

    .faiza-cat__name {
      transition: none;
    }

    .faiza-cat__link:hover .faiza-cat__frame,
    .faiza-cat__link:focus-visible .faiza-cat__frame {
      transform: none;
    }

    .faiza-cat__link:hover .faiza-cat__img,
    .faiza-cat__link:focus-visible .faiza-cat__img {
      transform: none;
    }

    .faiza-cat__link:hover .faiza-cat__cta-text,
    .faiza-cat__link:focus-visible .faiza-cat__cta-text {
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Faiza Category Grid",
  "tag": "section",
  "class": "faiza-cat-section",
  "settings": [
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Section spacing",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Explore Our Range"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop By Category"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Faiza Category Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Oud" } },
        { "type": "category", "settings": { "title": "Floral" } },
        { "type": "category", "settings": { "title": "Woody" } },
        { "type": "category", "settings": { "title": "Oriental" } },
        { "type": "category", "settings": { "title": "Citrus" } },
        { "type": "category", "settings": { "title": "Musk" } }
      ]
    }
  ]
}
{% endschema %}
