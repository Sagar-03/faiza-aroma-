<div
  class="faiza-testi full-width"
  style="--sec-pad: {{ section.settings.section_spacing }}px;"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  id="faiza-testi-{{ section.id }}"
>
  <div class="faiza-testi__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="faiza-testi__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="faiza-testi__eyebrow">
            <span class="faiza-testi__rule" aria-hidden="true"></span>
            {{- section.settings.eyebrow | escape -}}
            <span class="faiza-testi__rule" aria-hidden="true"></span>
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="faiza-testi__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="faiza-testi__carousel" aria-label="{{ 'sections.faiza_testi.aria_label' | t | default: 'Customer reviews' }}" role="region">
      <div class="faiza-testi__track-wrap">
        <div class="faiza-testi__track" id="faiza-testi-track-{{ section.id }}" aria-live="polite">
          {%- for block in section.blocks -%}
            <div
              class="faiza-testi__slide{% if forloop.first %} faiza-testi__slide--active{% endif %}"
              role="group"
              aria-roledescription="slide"
              aria-label="{{ forloop.index }} / {{ section.blocks.size }}"
              aria-hidden="{{ forloop.first | default: 'false' | unless: forloop.first }}{% if forloop.first %}false{% else %}true{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="faiza-testi__card">
                <div class="faiza-testi__quote-icon" aria-hidden="true">
                  <svg viewBox="0 0 40 30" fill="currentColor">
                    <path d="M0 30V18C0 7 6 2 18 0l2 4C13 5 9 9 9 14v1h9v15H0zm22 0V18C22 7 28 2 40 0l2 4C35 5 31 9 31 14v1h9v15H22z"/>
                  </svg>
                </div>

                {%- if block.settings.review != blank -%}
                  <blockquote class="faiza-testi__review">{{ block.settings.review | escape }}</blockquote>
                {%- endif -%}

                <div class="faiza-testi__stars" aria-label="{{ block.settings.rating }} {{ 'general.out_of' | t | default: 'out of' }} 5">
                  {%- for i in (1..5) -%}
                    <svg
                      class="faiza-testi__star{% if i <= block.settings.rating %} faiza-testi__star--filled{% endif %}"
                      viewBox="0 0 14 14"
                      aria-hidden="true"
                    >
                      <polygon points="7,1 8.8,5.2 13.5,5.2 9.9,8.2 11.2,13 7,10.4 2.8,13 4.1,8.2 0.5,5.2 5.2,5.2"/>
                    </svg>
                  {%- endfor -%}
                </div>

                <div class="faiza-testi__author">
                  {%- if block.settings.customer_image != blank -%}
                    <div class="faiza-testi__avatar">
                      {{
                        block.settings.customer_image
                        | image_url: width: 120
                        | image_tag:
                          loading: 'lazy',
                          class: 'faiza-testi__avatar-img',
                          alt: block.settings.customer_name | default: '' | escape
                      }}
                    </div>
                  {%- else -%}
                    <div class="faiza-testi__avatar faiza-testi__avatar--initials" aria-hidden="true">
                      {{- block.settings.customer_name | default: 'A' | slice: 0, 1 | upcase -}}
                    </div>
                  {%- endif -%}

                  <div class="faiza-testi__author-info">
                    {%- if block.settings.customer_name != blank -%}
                      <span class="faiza-testi__author-name">{{ block.settings.customer_name | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.customer_location != blank -%}
                      <span class="faiza-testi__author-location">{{ block.settings.customer_location | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.verified -%}
                      <span class="faiza-testi__verified">
                        <svg viewBox="0 0 14 14" fill="currentColor" aria-hidden="true"><path d="M7 0L8.5 2.5L11.5 2L11 5L14 7L11 9L11.5 12L8.5 11.5L7 14L5.5 11.5L2.5 12L3 9L0 7L3 5L2.5 2L5.5 2.5Z"/></svg>
                        {{- 'sections.faiza_testi.verified' | t | default: 'Verified buyer' -}}
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          {%- else -%}
            {%- for i in (1..3) -%}
              <div class="faiza-testi__slide{% if forloop.first %} faiza-testi__slide--active{% endif %}">
                <div class="faiza-testi__card">
                  <div class="faiza-testi__quote-icon" aria-hidden="true">
                    <svg viewBox="0 0 40 30" fill="currentColor">
                      <path d="M0 30V18C0 7 6 2 18 0l2 4C13 5 9 9 9 14v1h9v15H0zm22 0V18C22 7 28 2 40 0l2 4C35 5 31 9 31 14v1h9v15H22z"/>
                    </svg>
                  </div>
                  <blockquote class="faiza-testi__review">An exquisite fragrance that lingers beautifully throughout the day. Truly a work of art in a bottle.</blockquote>
                  <div class="faiza-testi__stars">
                    {%- for s in (1..5) -%}
                      <svg class="faiza-testi__star faiza-testi__star--filled" viewBox="0 0 14 14"><polygon points="7,1 8.8,5.2 13.5,5.2 9.9,8.2 11.2,13 7,10.4 2.8,13 4.1,8.2 0.5,5.2 5.2,5.2"/></svg>
                    {%- endfor -%}
                  </div>
                  <div class="faiza-testi__author">
                    <div class="faiza-testi__avatar faiza-testi__avatar--initials" aria-hidden="true">A</div>
                    <div class="faiza-testi__author-info">
                      <span class="faiza-testi__author-name">Aisha Rahman</span>
                      <span class="faiza-testi__author-location">Dubai, UAE</span>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      {%- if section.blocks.size > 1 or section.blocks == empty -%}
        <div class="faiza-testi__controls">
          <button
            class="faiza-testi__arrow faiza-testi__arrow--prev"
            aria-label="{{ 'general.slider.previous_slide' | t | default: 'Previous' }}"
            data-prev
          >
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M13 5l-5 5 5 5"/>
            </svg>
          </button>

          <div class="faiza-testi__dots" role="tablist" aria-label="{{ 'general.slider.dots' | t | default: 'Slides' }}">
            {%- assign dot_count = section.blocks.size | default: 3 -%}
            {%- for i in (1..dot_count) -%}
              <button
                class="faiza-testi__dot{% if forloop.first %} faiza-testi__dot--active{% endif %}"
                role="tab"
                aria-selected="{{ forloop.first }}"
                aria-label="{{ 'general.slider.slide' | t | default: 'Slide' }} {{ forloop.index }}"
                data-dot="{{ forloop.index0 }}"
              ></button>
            {%- endfor -%}
          </div>

          <button
            class="faiza-testi__arrow faiza-testi__arrow--next"
            aria-label="{{ 'general.slider.next_slide' | t | default: 'Next' }}"
            data-next
          >
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M7 5l5 5-5 5"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% stylesheet %}
  /* ─── Section ─── */
  .faiza-testi {
    padding: var(--sec-pad, 24px) 0;
    background-color: #faf8f5;
    overflow: hidden;
    position: relative;
  }

  .faiza-testi::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        45deg,
        rgba(201, 169, 110, 0.025) 0px,
        rgba(201, 169, 110, 0.025) 1px,
        transparent 1px,
        transparent 28px
      ),
      repeating-linear-gradient(
        -45deg,
        rgba(201, 169, 110, 0.025) 0px,
        rgba(201, 169, 110, 0.025) 1px,
        transparent 1px,
        transparent 28px
      );
    pointer-events: none;
  }

  .faiza-testi__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  /* ─── Header ─── */
  .faiza-testi__header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .faiza-testi__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 1.25rem;
  }

  .faiza-testi__rule {
    display: block;
    flex-shrink: 0;
    width: 2.25rem;
    height: 1px;
    background-color: #c9a96e;
  }

  .faiza-testi__heading {
    font-family: var(--font-heading-family, serif);
    font-size: clamp(1.875rem, 3.5vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: #1a1614;
    margin: 0;
  }

  /* ─── Carousel ─── */
  .faiza-testi__carousel {
    position: relative;
  }

  .faiza-testi__track-wrap {
    overflow: hidden;
    touch-action: pan-y;
  }

  .faiza-testi__track {
    display: flex;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ─── Slide ─── */
  .faiza-testi__slide {
    min-width: 100%;
    padding: 0 0.75rem;
    box-sizing: border-box;
  }

  /* ─── Card ─── */
  .faiza-testi__card {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.75rem 2.5rem;
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
    position: relative;
  }

  .faiza-testi__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 169, 110, 0.6) 30%,
      rgba(240, 208, 144, 0.9) 50%,
      rgba(201, 169, 110, 0.6) 70%,
      transparent
    );
  }

  /* ─── Quote icon ─── */
  .faiza-testi__quote-icon {
    width: 2rem;
    height: auto;
    color: rgba(201, 169, 110, 0.25);
    margin-bottom: 1.25rem;
  }

  .faiza-testi__quote-icon svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ─── Review text ─── */
  .faiza-testi__review {
    font-family: var(--font-heading-family, serif);
    font-size: clamp(1rem, 1.8vw, 1.3125rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.75;
    letter-spacing: 0.01em;
    color: rgba(26, 22, 20, 0.82);
    margin: 0 0 1.75rem;
    quotes: none;
  }

  /* ─── Stars ─── */
  .faiza-testi__stars {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.75rem;
  }

  .faiza-testi__star {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    fill: rgba(26, 22, 20, 0.10);
    stroke: none;
  }

  .faiza-testi__star--filled {
    fill: #c9a96e;
    stroke: none;
  }

  /* ─── Author ─── */
  .faiza-testi__author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .faiza-testi__avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 1.5px solid rgba(201, 169, 110, 0.3);
  }

  .faiza-testi__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .faiza-testi__avatar--initials {
    background-color: #f0ece6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading-family, serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: #c9a96e;
  }

  .faiza-testi__author-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .faiza-testi__author-name {
    font-family: var(--font-heading-family, serif);
    font-size: 1rem;
    font-weight: 400;
    color: #1a1614;
    letter-spacing: 0.04em;
  }

  .faiza-testi__author-location {
    font-family: var(--font-body-family, sans-serif);
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: rgba(26, 22, 20, 0.45);
  }

  .faiza-testi__verified {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c9a96e;
    opacity: 0.7;
  }

  .faiza-testi__verified svg {
    width: 0.625rem;
    height: 0.625rem;
    flex-shrink: 0;
  }

  /* ─── Controls ─── */
  .faiza-testi__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .faiza-testi__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background-color: transparent;
    border: 1px solid rgba(201, 169, 110, 0.3);
    color: rgba(201, 169, 110, 0.7);
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease, background-color 0.25s ease;
  }

  .faiza-testi__arrow:hover {
    border-color: #c9a96e;
    color: #c9a96e;
    background-color: rgba(201, 169, 110, 0.06);
  }

  .faiza-testi__arrow svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  /* ─── Dots ─── */
  .faiza-testi__dots {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .faiza-testi__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    padding: 0;
    background-color: rgba(201, 169, 110, 0.25);
    cursor: pointer;
    transition: background-color 0.25s ease, transform 0.25s ease, width 0.25s ease;
  }

  .faiza-testi__dot--active {
    background-color: #c9a96e;
    width: 1.5rem;
    border-radius: 0.25rem;
    transform: none;
  }

  /* ─── Tablet ─── */
  @media screen and (min-width: 750px) {
    .faiza-testi__inner { padding: 0 2.5rem; }
    .faiza-testi__card { padding: 3rem; }
  }

  /* ─── Desktop ─── */
  @media screen and (min-width: 990px) {
    .faiza-testi__inner { padding: 0 3rem; }
    .faiza-testi__card { padding: 3.5rem 4rem; }
  }

  @media screen and (min-width: 1440px) {
    .faiza-testi__inner { padding: 0 4.5rem; }
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .faiza-testi__track { transition: none; }
    .faiza-testi__arrow, .faiza-testi__dot { transition: none; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const ROOT = document.getElementById('faiza-testi-{{ section.id }}');
    if (!ROOT) return;

    const track = ROOT.querySelector('.faiza-testi__track');
    const slides = Array.from(ROOT.querySelectorAll('.faiza-testi__slide'));
    const dots = Array.from(ROOT.querySelectorAll('[data-dot]'));
    const prevBtn = ROOT.querySelector('[data-prev]');
    const nextBtn = ROOT.querySelector('[data-next]');
    const total = slides.length;
    const doAutoplay = ROOT.dataset.autoplay === 'true';
    const speed = parseInt(ROOT.dataset.speed, 10) || 5000;

    let current = 0;
    let timer = null;
    let touchStartX = 0;
    let touchDeltaX = 0;
    let isDragging = false;

    function go(index) {
      current = (index + total) % total;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      slides.forEach(function (s, i) {
        const active = i === current;
        s.classList.toggle('faiza-testi__slide--active', active);
        s.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach(function (d, i) {
        const active = i === current;
        d.classList.toggle('faiza-testi__dot--active', active);
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function startAutoplay() {
      if (!doAutoplay || total < 2) return;
      clearInterval(timer);
      timer = setInterval(function () { go(current + 1); }, speed);
    }

    function stopAutoplay() {
      clearInterval(timer);
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { stopAutoplay(); go(current - 1); startAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { stopAutoplay(); go(current + 1); startAutoplay(); });
    dots.forEach(function (d) {
      d.addEventListener('click', function () {
        stopAutoplay();
        go(parseInt(d.dataset.dot, 10));
        startAutoplay();
      });
    });

    /* Touch / swipe */
    var wrap = ROOT.querySelector('.faiza-testi__track-wrap');
    if (wrap) {
      wrap.addEventListener('touchstart', function (e) {
        touchStartX = e.touches[0].clientX;
        isDragging = true;
        stopAutoplay();
      }, { passive: true });

      wrap.addEventListener('touchmove', function (e) {
        if (!isDragging) return;
        touchDeltaX = e.touches[0].clientX - touchStartX;
      }, { passive: true });

      wrap.addEventListener('touchend', function () {
        if (!isDragging) return;
        isDragging = false;
        if (Math.abs(touchDeltaX) > 40) {
          go(touchDeltaX < 0 ? current + 1 : current - 1);
        }
        touchDeltaX = 0;
        startAutoplay();
      });
    }

    ROOT.addEventListener('mouseenter', stopAutoplay);
    ROOT.addEventListener('mouseleave', startAutoplay);

    /* Keyboard */
    ROOT.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') { stopAutoplay(); go(current - 1); startAutoplay(); }
      if (e.key === 'ArrowRight') { stopAutoplay(); go(current + 1); startAutoplay(); }
    });

    startAutoplay();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Faiza Testimonials",
  "tag": "section",
  "class": "faiza-testi-section",
  "settings": [
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Section spacing",
      "min": 8,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Loved by Thousands"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "customer_image",
          "label": "Customer photo"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name",
          "default": "Sarah Al-Mansoori"
        },
        {
          "type": "text",
          "id": "customer_location",
          "label": "Location",
          "default": "Dubai, UAE"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Review text",
          "default": "An absolutely stunning fragrance. The longevity is exceptional and I receive compliments everywhere I go. Truly a signature scent worth every penny."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Faiza Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "customer_name": "Aisha Rahman",
            "customer_location": "Riyadh, KSA",
            "rating": 5,
            "review": "An exquisite fragrance that lingers beautifully. The bottle itself is a work of art and the scent is nothing short of magical. Highly recommend.",
            "verified": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "customer_name": "Fatima Al-Zahra",
            "customer_location": "London, UK",
            "rating": 5,
            "review": "I have tried many luxury fragrances but Faiza Aroma stands apart. The depth, the warmth, the trail it leaves — absolutely captivating.",
            "verified": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "customer_name": "Noor Hassan",
            "customer_location": "Toronto, Canada",
            "rating": 5,
            "review": "Gifted this to my mother and she hasn't stopped wearing it. The packaging is gorgeous and the scent is rich and sophisticated.",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
