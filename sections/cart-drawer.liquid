{% comment %}
  Cart Drawer Section
{% endcomment %}

<div id="CartDrawer" class="cart-drawer">
  <div class="cart-drawer__overlay"></div>

  <aside
    class="cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-label="Shopping cart"
  >
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart</h2>

      <button
        type="button"
        class="cart-drawer__close"
        aria-label="Close cart"
      >
        &times;
      </button>
    </div>

    <div class="cart-drawer__content">
      {% if cart.item_count > 0 %}

        {% for item in cart.items %}
          <div class="cart-item">

            <a href="{{ item.url }}" class="cart-item__image">
              {% if item.image %}
                {{
                  item.image
                  | image_url: width: 200
                  | image_tag:
                    loading: 'lazy',
                    alt: item.product.title
                }}
              {% endif %}
            </a>

            <div class="cart-item__details">

              <a href="{{ item.url }}" class="cart-item__title">
                {{ item.product.title }}
              </a>

              {% unless item.variant.title == 'Default Title' %}
                <div class="cart-item__variant">
                  {{ item.variant.title }}
                </div>
              {% endunless %}

              <div class="cart-item__price">
                {{ item.final_price | money }}
              </div>

              <div class="cart-item__bottom">
                <div class="cart-item__qty">
                  <button
                    type="button"
                    class="cart-item__qty-btn"
                    data-action="decrease"
                    data-key="{{ item.key }}"
                    aria-label="Decrease quantity"
                  >−</button>
                  <span class="cart-item__qty-count" data-key="{{ item.key }}">{{ item.quantity }}</span>
                  <button
                    type="button"
                    class="cart-item__qty-btn"
                    data-action="increase"
                    data-key="{{ item.key }}"
                    aria-label="Increase quantity"
                  >+</button>
                </div>

                <button
                  type="button"
                  class="cart-item__remove"
                  data-key="{{ item.key }}"
                >
                  Remove
                </button>
              </div>

            </div>
          </div>
        {% endfor %}

      {% else %}

        <div class="cart-drawer__empty">
          <p>Your cart is empty.</p>

          <a href="{{ routes.all_products_collection_url }}" class="button">
            Continue Shopping
          </a>
        </div>

      {% endif %}
    </div>

    {% if cart.item_count > 0 %}
      <div class="cart-drawer__footer">

        <div class="cart-drawer__subtotal">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        <form action="{{ routes.cart_url }}" method="post">
          <button
            type="submit"
            name="checkout"
            class="cart-drawer__button cart-drawer__button--primary"
          >
            <span class="cart-drawer__button-label">Order now</span>
            <span class="cart-drawer__button-icons" aria-hidden="true">
              <span class="payment-icon payment-icon--paytm">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20"><rect width="32" height="32" rx="16" fill="#00BAF2"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#fff" font-size="8" font-weight="700" font-family="Arial">Pay</text></svg>
              </span>
              <span class="payment-icon payment-icon--phonepe">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20"><rect width="32" height="32" rx="16" fill="#5F259F"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#fff" font-size="9" font-weight="700" font-family="Arial">Pe</text></svg>
              </span>
              <span class="payment-icon payment-icon--gpay">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20"><rect width="32" height="32" rx="16" fill="#fff"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#4285F4" font-size="7" font-weight="700" font-family="Arial">GPay</text></svg>
              </span>
            </span>
          </button>
        </form>

      </div>
    {% endif %}
  </aside>
</div>

<style>
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    visibility: hidden;
    pointer-events: none;
  }

  .cart-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cart-drawer.is-open .cart-drawer__overlay {
    opacity: 1;
  }

  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    width: 420px;
    max-width: 100%;
    height: 100%;
    background: #f8f6f2;
    color: #1a1614;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 24px rgba(0, 0, 0, 0.15);
  }

  .cart-drawer.is-open .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px;
    border-bottom: 1px solid rgba(201, 169, 110, 0.2);
  }

  .cart-drawer__title {
    margin: 0;
    font-size: 1.5rem;
  }

  .cart-drawer__close {
    border: 0;
    background: transparent;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
  }

  .cart-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .cart-item__image img {
    width: 100%;
    display: block;
    border-radius: 8px;
  }

  .cart-item__title {
    display: block;
    color: #1a1614;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .cart-item__variant,
  .cart-item__price {
    margin-bottom: 6px;
    color: rgba(26, 22, 20, 0.75);
  }

  .cart-item__bottom {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(201, 169, 110, 0.4);
    border-radius: 20px;
    overflow: hidden;
  }

  .cart-item__qty-btn {
    background: transparent;
    border: none;
    width: 28px;
    height: 28px;
    font-size: 1rem;
    cursor: pointer;
    color: #1a1614;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .cart-item__qty-btn:hover {
    background: rgba(201, 169, 110, 0.15);
  }

  .cart-item__qty-count {
    min-width: 24px;
    text-align: center;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .cart-item__remove {
    background: none;
    border: none;
    padding: 0;
    color: #c9a96e;
    cursor: pointer;
    font-size: 0.8125rem;
    text-decoration: underline;
  }

  .cart-drawer__footer {
    padding: 24px;
    border-top: 1px solid rgba(201, 169, 110, 0.2);
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .cart-drawer__button {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0;
    text-decoration: none;
    border-radius: 50px;
    overflow: hidden;
    border: none;
    cursor: pointer;
  }

  .cart-drawer__button--primary {
    background: #c9a96e;
    color: #fff;
  }

  .cart-drawer__button-label {
    flex: 1;
    padding: 15px 20px;
    text-align: center;
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cart-drawer__button-icons {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 10px;
    background: rgba(0, 0, 0, 0.12);
    border-radius: 50px;
    margin: 4px;
  }

  .payment-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    overflow: hidden;
  }

  .cart-drawer__empty {
    text-align: center;
    padding: 40px 0;
  }

  @media (max-width: 480px) {
    .cart-drawer__panel {
      width: 100%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const drawer = document.getElementById('CartDrawer');

    if (!drawer) return;

    const overlay = drawer.querySelector('.cart-drawer__overlay');
    const closeButton = drawer.querySelector('.cart-drawer__close');

    function openDrawer() {
      drawer.classList.add('is-open');
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
    }

    document.querySelectorAll('a[href="/cart"], a[href="{{ routes.cart_url }}"]').forEach((link) => {
      link.addEventListener('click', function (event) {
        event.preventDefault();
        openDrawer();
      });
    });

    overlay.addEventListener('click', closeDrawer);
    closeButton.addEventListener('click', closeDrawer);

    if (sessionStorage.getItem('openCartDrawer') === '1') {
      sessionStorage.removeItem('openCartDrawer');
      openDrawer();
    }

    function updateCartItem(key, quantity) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: quantity }),
      })
        .then((res) => res.json())
        .then(() => {
          location.reload();
        });
    }

    drawer.addEventListener('click', function (e) {
      const btn = e.target.closest('.cart-item__qty-btn');
      if (btn) {
        const key = btn.dataset.key;
        const countEl = drawer.querySelector(`.cart-item__qty-count[data-key="${key}"]`);
        let qty = parseInt(countEl.textContent, 10);
        qty = btn.dataset.action === 'increase' ? qty + 1 : Math.max(0, qty - 1);
        countEl.textContent = qty;
        updateCartItem(key, qty);
        return;
      }

      const removeBtn = e.target.closest('.cart-item__remove');
      if (removeBtn) {
        updateCartItem(removeBtn.dataset.key, 0);
      }
    });
  });
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}